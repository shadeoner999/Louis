# ─────────────────────────────────────────────────────────────────────────────
# Louis — variables d'environnement
#
# Copier ce fichier en `.env` puis remplir les valeurs.
# Ne JAMAIS committer le fichier `.env` (cf. .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
# URL de la documentation publique (boutons d'aide « i » des modules).
# Défaut : https://louis.data-ring.net/docs. À surcharger seulement si vous
# hébergez votre propre miroir de la doc.
# NEXT_PUBLIC_DOCS_URL=https://louis.data-ring.net/docs

# Base de données (PostgreSQL + pgvector)
# Compatible avec le docker-compose.yml fourni (port 5433 pour ne pas
# entrer en conflit avec un Postgres système ou d'un autre projet local).
DATABASE_URL=postgresql://louis:louis@localhost:5433/louis

# Redis (cache, rate-limit)
REDIS_URL=redis://localhost:6379

# Object storage (S3-compatible — MinIO en dev, Scaleway/OVH/AWS en prod)
S3_ENDPOINT=http://localhost:9000
S3_REGION=eu-west-3
S3_BUCKET=louis
S3_ACCESS_KEY_ID=louis
S3_SECRET_ACCESS_KEY=louis-dev-only
S3_FORCE_PATH_STYLE=true

# Authentification (NextAuth v5)
# Générer une valeur avec : openssl rand -base64 32
AUTH_SECRET=

# Chiffrement des secrets utilisateur (clés providers IA, tokens connecteurs)
# Générer avec : openssl rand -base64 32
# ATTENTION : changer cette valeur invalide toutes les clés déjà stockées.
ENCRYPTION_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Providers IA (BYOK — Bring Your Own Key)
#
# Ces variables sont OPTIONNELLES. Louis privilégie le stockage par utilisateur
# via l'UI (page Providers). Les variables ci-dessous servent uniquement de
# *fallback global* pour les déploiements personnels ou les démos.
# ─────────────────────────────────────────────────────────────────────────────

# Mistral — https://console.mistral.ai/
MISTRAL_API_KEY=

# Scaleway Generative APIs — https://console.scaleway.com/
SCALEWAY_API_KEY=
SCALEWAY_PROJECT_ID=

# OVHcloud AI Endpoints — https://endpoints.ai.cloud.ovh.net/
OVH_AI_ENDPOINTS_API_KEY=

# Albert (Etalab) — https://albert.api.etalab.gouv.fr/
ALBERT_API_KEY=

# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI — https://platform.openai.com/
OPENAI_API_KEY=

# Endpoint OpenAI-compatible générique (Ollama, vLLM, llama.cpp, …)
# Exemple : http://localhost:11434/v1 pour Ollama
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Connecteurs juridiques (BYOK)
# ─────────────────────────────────────────────────────────────────────────────

# PISTE (api.gouv.fr) — passerelle commune Légifrance / Judilibre / JADE / INPI
# Inscription : https://piste.gouv.fr/
PISTE_CLIENT_ID=
PISTE_CLIENT_SECRET=

# Pappers (entreprises, dirigeants, bénéficiaires)
# https://www.pappers.fr/api
PAPPERS_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Génération de documents — conversion DOCX → PDF fidèle
# ─────────────────────────────────────────────────────────────────────────────

# Gotenberg (recommandé, fourni par docker-compose.yml)
# Sans cette variable, fallback sur le binaire LibreOffice local (brew install
# --cask libreoffice / apt install libreoffice), puis preview HTML mammoth en
# dernier recours.
GOTENBERG_URL=http://localhost:3001

# ─────────────────────────────────────────────────────────────────────────────
# Base de données — sécurité réseau
# ─────────────────────────────────────────────────────────────────────────────

# Force l'activation SSL même si la chaîne ne contient pas sslmode=. En prod
# managé (Scaleway / OVH / AWS RDS), mettre à `true`.
DATABASE_SSL=false

# Refuser les certificats non signés par une autorité reconnue.
# Default `true` en prod. À mettre à `false` UNIQUEMENT pour un Postgres
# self-hosted avec un certificat auto-signé (et seulement après avoir évalué le
# risque MITM).
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# ─────────────────────────────────────────────────────────────────────────────
# Rate-limiting (Phase 2 — durcissement sécurité)
# ─────────────────────────────────────────────────────────────────────────────

# Requêtes chat / minute / user authentifié. 0 = désactivé.
RATE_LIMIT_CHAT_PER_MINUTE=30

# Uploads document / heure / user authentifié. 0 = désactivé.
RATE_LIMIT_UPLOAD_PER_HOUR=60

# Tentatives login / 15 min / IP. 0 = désactivé.
RATE_LIMIT_LOGIN_PER_15MIN=10
